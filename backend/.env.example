# ====================== APPLICATION ======================
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
APP_NAME=Guest Management System
CLIENT_URL=http://localhost:5173

# ====================== DATABASE ======================
MONGODB_URI=mongodb://127.0.0.1:27017/guest_management
MONGODB_TEST_URI=mongodb://127.0.0.1:27017/guest_management_test

# ====================== JWT ======================
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# ====================== SECURITY ======================
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ====================== EMAIL (SMTP) ======================
# Leave SMTP_HOST/USER/PASSWORD blank to use the dev JSON-stream
# fallback transport (no real emails sent — envelopes go to logs).
# Fill them in to send real emails (e.g. smtp.gmail.com + a Gmail
# App Password). EMAIL_FROM_ADDRESS should match SMTP_USER for Gmail.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=CorpGMS
EMAIL_FROM_ADDRESS=no-reply@corpgms.local

# ====================== WHATSAPP (Meta Cloud API) ======================
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# ====================== LOGGING ======================
LOG_LEVEL=info
LOG_DIR=logs

# ====================== SUPER ADMIN SEED ======================
SUPER_ADMIN_EMAIL=superadmin@platform.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_NAME=Platform Owner

# ====================== ANTHROPIC (CHATBOT) ======================
ANTHROPIC_API_KEY=sk-ant-api03-replace_with_your_key

# ─── Referral ──────────────────────────────────────────
REFERRAL_REWARD_TYPE=DISCOUNT
REFERRAL_REWARD_VALUE=10
REFERRAL_EXPIRY_DAYS=90

# ─── Webhooks / API Integrations ───────────────────────
WEBHOOK_SECRET=gms_webhook_secret_change_this
WEBHOOK_TIMEOUT_MS=10000