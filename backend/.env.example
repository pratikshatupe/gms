# ──────────────────────────────────────────────────────────────────────
# Corporate Guest Management System — Backend env
# Copy this file to backend/.env and fill in the values.
# ──────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
API_PREFIX=/api/v1
APP_NAME=Guest Management System
CLIENT_URL=http://localhost:5173

# Database (MongoDB Atlas or local)
MONGO_URI=mongodb://localhost:27017/guestmanagement

# Auth — change in production
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Bootstrap super admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_NAME=Platform Owner

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ──────────────────────────────────────────────────────────────────────
# SMTP (used by notification.service.js for ALL outbound email:
# announcements, welcome emails, appointment confirmations, etc.)
# Leave SMTP_HOST blank to keep email in JSON-stream fallback mode (logs
# the envelope instead of sending). Gmail requires an App Password.
# ──────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=CorpGMS
EMAIL_FROM_ADDRESS=no-reply@corpgms.ae

# WhatsApp (optional — leave blank to skip)
WHATSAPP_API_URL=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Referral programme
REFERRAL_REWARD_TYPE=DISCOUNT
REFERRAL_REWARD_VALUE=10
REFERRAL_EXPIRY_DAYS=90

# Webhook
WEBHOOK_SECRET=change_me_webhook_secret
WEBHOOK_TIMEOUT_MS=10000

# ──────────────────────────────────────────────────────────────────────
# Razorpay (optional — leave blank to run the demo without payments).
# Backend boots fine without these; the payment endpoints will return a
# clear error if Razorpay is invoked while unconfigured. Test keys start
# with rzp_test_; rotate to live keys only in production.
# ──────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
